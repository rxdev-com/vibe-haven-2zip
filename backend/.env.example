# Backend environment variables
PORT=3001

# MongoDB connection string. If left empty, an in-memory MongoDB
# (mongodb-memory-server) is started automatically — perfect for development.
# For production, set MONGODB_URI to a MongoDB Atlas / self-hosted URI.
MONGODB_URI=

# JWT secret used to sign auth tokens. CHANGE THIS in production!
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated list of origins allowed by CORS. Use * to allow any.
CORS_ORIGIN=*

# Set to "true" to seed demo data on first startup
SEED_ON_START=true
